}
---
<Base title="Model Catalog — Freeloader" description="Browse free tier AI models available through Freeloader.">
  <Nav client:load />
  <main class="max-w-6xl mx-auto px-4 pt-28 pb-12">
    <div class="mb-10">
      <h1 class="font-heading text-3xl sm:text-5xl mb-4">
        Free Tier <span class="text-coupon">Coupon Book</span>
      </h1>
      <p class="font-typewriter text-faded max-w-2xl text-lg">
        {models.length} models from {new Set(models.map((m: any) => m.provider)).size} providers, sorted cheapest first.
        Freeloader exhausts the <span class="text-savings font-heading">$0</span> ones before touching anything that costs money.
      </p>
    </div>
    <CatalogCoupons models={models} client:load />
  </main>
  <Footer client:visible />
</Base>
