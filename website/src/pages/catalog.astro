import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.svelte';
import Footer from '../components/Footer.svelte';
import CatalogCoupons from '../components/CatalogCoupons.svelte';

// Flatten provider catalog into model list with provider info
function flattenCatalog(catalog: any) {
  if (!catalog?.providers) return [];
  return catalog.providers.flatMap((p: any) =>
    (p.models || []).map((m: any) => ({
      ...m,
      provider: p.name,
      trust_tier: m.trust_tier || p.trust_tier,
      routing_tier: m.routing_tier || 'budget',
      is_local: m.is_local || p.is_local || false,
    }))
  );
}

