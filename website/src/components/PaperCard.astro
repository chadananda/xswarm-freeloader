---
export interface Props {
  thickness?: 1 | 2 | 3;
  color?: string;
  class?: string;
}
const { thickness = 2, color = '#e8e0d0', class: className = '' } = Astro.props;
const colorStyle = `background-color: ${color};`;
---

<div class:list={['paper-card', `paper-card--t${thickness}`, className]}>
  <div class="paper-card__back" style={colorStyle}></div>
  <div class="paper-card__front" style={colorStyle}>
    <div class="paper-card__grain"></div>
  </div>
  <div class="paper-card__content"><slot /></div>
</div>

<style>
  .paper-card { position: relative; }
  .paper-card__back, .paper-card__front {
    position: absolute; inset: 0;
    background-image: var(--paper-surface);
    background-size: 200px, 100%; background-repeat: repeat, no-repeat;
    background-blend-mode: multiply;
    border-radius: 3px 4px 5px 4px;
    filter: url(#papercut);
    box-shadow: var(--shadow-contact), var(--shadow-edge);
  }
  .paper-card__back {
    transform: translate(1px, 1px);
    filter: url(#papercut) drop-shadow(0 0 4px rgba(30,20,10,0.22)) drop-shadow(0 0 8px rgba(30,20,10,0.08));
  }
  .paper-card__front { z-index: 1; }
  .paper-card__grain {
    position: absolute; inset: 0; pointer-events: none;
    background-image: var(--noise-grain);
    background-size: 300px; background-repeat: repeat;
    mix-blend-mode: multiply; opacity: 0.7; border-radius: inherit;
  }
  .paper-card__content { position: relative; z-index: 1; height: 100%; }
</style>
