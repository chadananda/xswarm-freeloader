{
  "name": "xswarm-freeloader",
  "version": "2.0.0",
  "description": "Intelligent AI router that maximizes free tier usage across 100+ LLM providers",
  "type": "module",
  "main": "src/router/server.js",
  "bin": {
    "xswarm-freeloader": "src/bin/cli.js"
  },
  "scripts": {
    "start": "node src/router/server.js",
    "dev": "node --watch src/router/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "dashboard:dev": "cd src/dashboard && npx vite dev",
    "dashboard:build": "cd src/dashboard && npx vite build"
  },
  "keywords": [
    "ai",
    "llm",
    "router",
    "free-tier",
    "anthropic",
    "openai",
    "cost-optimization",
    "xswarm"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chadananda/xswarm-freeloader.git"
  },
  "bugs": {
    "url": "https://github.com/chadananda/xswarm-freeloader/issues"
  },
  "homepage": "https://github.com/chadananda/xswarm-freeloader#readme",
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.2",
    "bcrypt": "^5.1.0",
    "better-sqlite3": "^11.9.1",
    "fastify": "^5.2.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^6.9.0",
    "pdfkit": "^0.17.2",
    "pino": "^9.6.0",
    "pino-pretty": "^11.0.0",
    "xswarm-ai-sanitize": "^1.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.18.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
